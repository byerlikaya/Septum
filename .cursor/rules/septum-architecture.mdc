### STEP 8 — policy_composer.py

PolicyComposer:
    def compose(self, db: Session) -> ComposedPolicy:
        active_regs = db.query(RegulationRuleset).filter_by(is_active=True).all()
        active_custom = db.query(CustomRecognizer).filter_by(is_active=True).all()

        entity_types = set()
        for reg in active_regs:
            entity_types.update(reg.entity_types)

        recognizers = recognizer_registry.build(active_regs, active_custom)

        return ComposedPolicy(
            entity_types=list(entity_types),
            recognizers=recognizers,
            regulation_ids=[r.id for r in active_regs]
        )

    ComposedPolicy:
        entity_types: List[str]
        recognizers: List[EntityRecognizer]
        regulation_ids: List[str]

### STEP 9 — sanitizer.py

PIISanitizer:
    def __init__(self, policy: ComposedPolicy, settings: AppSettings): ...

    def sanitize(self, text: str, language: str,
                 anon_map: AnonymizationMap) -> SanitizeResult:
        text = normalize_unicode(text)
        spans = []
        # Layer 1: Presidio with composed recognizers + detected language
        if settings.use_presidio_layer:
            analyzer = AnalyzerEngine()
            for r in policy.recognizers:
                analyzer.registry.add_recognizer(r)
            results = analyzer.analyze(text=text, language=language,
                                       entities=policy.entity_types)
            spans += results

        # Layer 2: Language-specific NER
        if settings.use_ner_layer:
            ner = ner_model_registry.get_pipeline(language)
            spans += self._ner_to_spans(ner(text))

        # Deduplicate, apply anonymization map, coreference resolution
        spans = self._deduplicate(spans)
        sanitized, count = self._apply_replacements(text, spans, anon_map, language)
        sanitized = anon_map.apply_blocklist(sanitized, language)
        self._log_low_confidence(spans)
        return SanitizeResult(sanitized_text=sanitized, entity_count=count)

### STEP 10 — anonymization_map.py

AnonymizationMap (session-scoped, language-aware coreference):
    entity_map: dict[str, str]
    blocklist: set[str]
    token_counter: dict[str, int]
    document_id: int
    language: str

    add_entity(original, entity_type) → placeholder
    apply_blocklist(text, language) → text with partial matches replaced
    _find_existing(original) → Optional[placeholder]

    apply_blocklist uses locale_lower(token, language) for correct comparison.
    Short tokens (<= 2 chars) excluded from blocklist regardless of language.

