device.py:
    def get_device() -> str:
        if torch.backends.mps.is_available(): return "mps"
        if torch.cuda.is_available():          return "cuda"
        return "cpu"

text_utils.py — locale-aware, NOT hardcoded for any single language:
    def normalize_unicode(text: str) -> str:
        return unicodedata.normalize("NFC", text)

    def locale_lower(text: str, language: str = "en") -> str:
        # Handle locale-specific casing rules
        # Turkish: İ→i, I→ı
        # German: ß→ss in some contexts (handled by locale lib)
        # Default: standard .lower() for all others
        LOCALE_TRANSFORMS = {
            "tr": str.maketrans("İI", "ii"),
        }
        transform = LOCALE_TRANSFORMS.get(language)
        if transform:
            return text.translate(transform).lower()
        return text.lower()

    def normalize_for_comparison(text: str, language: str = "en") -> str:
        return locale_lower(normalize_unicode(text), language)

