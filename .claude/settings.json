{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/pre-commit-check.sh",
            "if": "Bash(git commit *)",
            "timeout": 15,
            "statusMessage": "Running pre-commit checks..."
          }
        ]
      }
    ]
  }
}
