# -----------------------------------------------------------------------------
# Septum — docker-compose and app config (copy to .env)
# Backend and frontend read these when run via docker-compose.
# -----------------------------------------------------------------------------

# --- Compose / ports ---
BACKEND_PORT=8000
FRONTEND_PORT=3000
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:8000
OLLAMA_PORT=11434

# --- Backend (API) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# LLM_PROVIDER and LLM_MODEL are used ONLY for initial database seed (first run).
# After that, changes are made via Settings UI and persisted in the database.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5
USE_OLLAMA=false
# When running with: docker compose --profile ollama up → use OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_DEANON_MODEL=llama3.2:3b
WHISPER_MODEL=base
ENCRYPTION_KEY=
LOG_LEVEL=INFO
DB_PATH=./septum.db
REQUIRE_APPROVAL_DEFAULT=false
DEANON_ENABLED_DEFAULT=true
DEANON_STRATEGY=simple
MAX_FILE_SIZE_MB=100
DEFAULT_OCR_LANGUAGES=en
DEFAULT_ACTIVE_REGULATIONS=gdpr
