# -----------------------------------------------------------------------------
# Septum — docker-compose and app config (copy to .env)
# Backend and frontend read these when run via docker-compose.
# -----------------------------------------------------------------------------

# --- Compose / ports ---
BACKEND_PORT=8000
FRONTEND_PORT=3000
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:8000
OLLAMA_PORT=11434
POSTGRES_PORT=5432

# --- PostgreSQL (used by docker-compose; leave empty for local SQLite dev) ---
POSTGRES_PASSWORD=septum_secret
# DATABASE_URL is auto-set inside docker-compose.yml.
# For local dev with PostgreSQL, uncomment:
# DATABASE_URL=postgresql+asyncpg://septum:septum_secret@localhost:5432/septum

# --- Redis (optional; leave empty to disable Redis caching) ---
# REDIS_URL is auto-set inside docker-compose.yml.
# For local dev with Redis, uncomment:
# REDIS_URL=redis://localhost:6379/0

# --- Authentication ---
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRATION_MINUTES=1440

# --- Rate Limiting ---
# RATE_LIMIT_DEFAULT=60/minute

# --- Backend (API) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# LLM_PROVIDER and LLM_MODEL are used ONLY for initial database seed (first run).
# After that, changes are made via Settings UI and persisted in the database.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5
USE_OLLAMA=false
# When running with: docker compose --profile ollama up → use OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_DEANON_MODEL=llama3.2:3b
WHISPER_MODEL=base
ENCRYPTION_KEY=
LOG_LEVEL=INFO
DB_PATH=./septum.db
REQUIRE_APPROVAL_DEFAULT=false
DEANON_ENABLED_DEFAULT=true
DEANON_STRATEGY=simple
MAX_FILE_SIZE_MB=100
DEFAULT_OCR_LANGUAGES=en
DEFAULT_ACTIVE_REGULATIONS=gdpr
