OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_DEANON_MODEL=llama3.2:3b
WHISPER_MODEL=base
# Required for loading saved anonymization maps after restart (deanonymization in chat).
# Generate once: python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=
LOG_LEVEL=INFO
# On macOS, set OMP_NUM_THREADS=1 in the shell to avoid OMP Error #179 (pthread_mutex_init) with PyTorch/MPS.
DB_PATH=./septum.db
ANON_MAP_STORAGE_DIR=./anon_maps
REQUIRE_APPROVAL_DEFAULT=false
DEANON_ENABLED_DEFAULT=true
DEANON_STRATEGY=simple
MAX_FILE_SIZE_MB=100
DEFAULT_OCR_LANGUAGES=en
DEFAULT_ACTIVE_REGULATIONS=gdpr
