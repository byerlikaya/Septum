# Keep the Docker build context lean: per-module images only need the
# package they are building, never the entire repo. These exclusions
# shave several hundred MB off the context on a fresh checkout.

# VCS / dev junk
.git/
.gitignore
.github/
.vscode/
.idea/
.cursor/
.claude/
.pytest_cache/
.mypy_cache/
.ruff_cache/
__pycache__/
*.pyc
*.pyo
*.pyd

# Node build artifacts (web rebuilds from source in the image)
node_modules/
packages/web/node_modules/
packages/web/.next/
packages/web/coverage/
packages/web/.env.local

# Backend artifacts + runtime state that never belongs in the image
backend/__pycache__/
backend/.venv/
backend/venv/
backend/data/
backend/uploads/
backend/anon_maps/
backend/vector_indexes/
backend/bm25_indexes/
backend/models/
backend/*.db
backend/*.log

# Top-level runtime state (from local dev runs)
/data/
/uploads/
/anon_maps/
/vector_indexes/
/bm25_indexes/
/models/
/documents/
/*.db
/*.log
/septum.db

# Screenshots / assets that docs pull from, never the image
screenshots/

# Docker itself
docker-compose*.yml
docker/
Dockerfile
.dockerignore

# Test + CI scripts
dev.sh
kickstart.sh
